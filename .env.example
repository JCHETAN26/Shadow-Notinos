# ---- Database ----
# Local Postgres (pgvector) from infra/docker-compose.yml
DATABASE_URL="postgresql://shadow:shadow@localhost:5435/shadow_notino?schema=public"

# ---- Redis / BullMQ ----
REDIS_URL="redis://localhost:6379"

# ---- GitHub ----
GITHUB_WEBHOOK_SECRET=""
GITHUB_TOKEN=""

# ---- Anthropic (Claude) ----
ANTHROPIC_API_KEY=""

# ---- Notion ----
NOTION_API_KEY=""
# Parent page the seeder creates the databases under. Share this page with your
# integration. Only needed to run `pnpm notion:seed` (not once the IDs below are set).
NOTION_PARENT_PAGE_ID=""
NOTION_ENGINEERING_DOCS_DATABASE_ID=""
NOTION_SERVICES_DATABASE_ID=""
NOTION_AGENT_RUNS_DATABASE_ID=""
NOTION_PR_UPDATES_DATABASE_ID=""
NOTION_REVIEW_TASKS_DATABASE_ID=""

# ---- App ----
API_PORT="4000"
WEB_PORT="3000"
# Base URL the web app uses to reach the API
NEXT_PUBLIC_API_URL="http://localhost:4000"
